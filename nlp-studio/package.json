{
  "name": "nlp-studio",
  "private": true,
  "version": "1.0.0",
  "description": "Enterprise-grade client-side NLP web application with sentiment analysis, NER, summarization, translation, and intent detection",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "devDependencies": {
    "vite": "^5.4.0",
    "vitest": "^2.0.0",
    "jsdom": "^24.0.0",
    "eslint": "^9.0.0",
    "@playwright/test": "^1.45.0"
  },
  "dependencies": {
    "compromise": "^14.14.0",
    "dompurify": "^3.1.0"
  }
}
