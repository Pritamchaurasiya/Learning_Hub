4 text-yellow-400 fill-yellow-400\" />\n              <span className=\"text-white text-sm font-medium\">Trusted by 1,00,000+ Students</span>\n            </motion.div>\n\n            {/* Headline */}\n            <h1 className=\"text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6\">\n              Master Your Exam with <span className=\"text-yellow-300\">India's Best</span> Practice\n              Platform\n            </h1>\n\n            {/* Subheadline */}\n            <p className=\"text-lg sm:text-xl text-blue-100 mb-8 max-w-xl\">\n              Chapter-wise Previous Year Questions ΓÇó Detailed Step-by-Step Solutions ΓÇó Smart\n              Analytics to Track Your Progress\n            </p>\n\n            {/* CTAs */}\n            <div className=\"flex flex-col sm:flex-row gap-4 mb-10\">\n              <Button\n                size=\"lg\"\n                onClick={onStartFree}\n                className=\"bg-white text-blue-700 hover:bg-blue-50 font-semibold px-8 py-4 text-lg shadow-xl\"\n              >\n                Start Free Practice\n                <ArrowRight className=\"w-5 h-5 ml-2\" />\n              </Button>\n              <Button\n                size=\"lg\"\n                variant=\"outline\"\n                onClick={onViewDemo}\n                className=\"border-white/30 text-white hover:bg-white/10 px-8 py-4 text-lg\"\n              >\n                <Play className=\"w-5 h-5 mr-2\" />\n                View Demo\n              </Button>\n            </div>\n\n            {/* Trust Indicators */}\n            <div className=\"flex flex-wrap items-center gap-6 text-white/80 text-sm\">\n              <div className=\"flex items-center gap-2\">\n                <BookOpen className=\"w-5 h-5\" />\n                <span>1L+ Questions</span>\n              </div>\n              <div className=\"flex items-center gap-2\">\n                <Users className=\"w-5 h-5\" />\n                <span>50K+ Daily Practice</span>\n   