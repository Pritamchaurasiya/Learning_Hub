n    error: (message: string, error: unknown) => {\n      console.error(formatMessage(message), error)\n    },\n    warn: (message: string, data?: unknown) => {\n      console.warn(formatMessage(message), data)\n    },\n    info: (message: string, data?: unknown) => {\n      console.info(formatMessage(message), data)\n    },\n    group: (label: string) => {\n      console.group(formatMessage(label))\n    },\n    groupEnd: () => {\n      console.groupEnd()\n    },\n    time: (label: string) => {\n      console.time(formatMessage(label))\n    },\n    timeEnd: (label: string) => {\n      console.timeEnd(formatMessage(label))\n    },\n  }\n}\n\nexport function enableDebug() {\n  config.enabled = true\n}\n\nexport function disableDebug() {\n  config.enabled = false\n}\n\nexport function setDebugConfig(newConfig: Partial<DebugConfig>) {\n  Object.assign(config, newConfig)\n}\n\nexport function getDebugConfig(): DebugConfig {\n  return { ...config }\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\shiva\\Desktop\\windows_app\\learninghub\\src\\utils\\logger.ts","messages":[{"ruleId":"no-console","severity":1,"message":"Unexpected console statement. Only these console methods are allowed: error, warn.","line":37,"column":7,"nodeType":"MemberExpression","messageId":"limited","endLine":37,"endColumn":20,"suggestions":[{"fix":{"range":[750,797],"text":""},"messageId":"removeConsole","data":{"propertyName":"debug"},"desc":"Remove the console.debug()."}]},{"ruleId":"no-console","severity":1,"message":"Unexpected console statement. Only these console methods are allowed: error, warn.","line":46,"column":7,"nodeType":"MemberExpression","messageId":"limited","endLine":46,"endColumn":19,"suggestions":[{"fix":{"range":[1015,1060],"text":""},"messageId":"removeConsole","data":{"propertyName":"info"},"desc":"Remove the console.info()."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"type LogLevel = 'debug' | 'info' | 'warn' | 'error'\n\ninterface LogEntry {\n  level: LogLevel\n  message: string\n  data?: unknown\n  timestamp: string\n  context?: string\n  userId?: string\n}\n\nconst isDevelopment = import.meta.env.DEV\nconst isProduction = import.meta.env.PROD\n\nclass Logger {\n  private logs: LogEntry[] = []\n  private maxLogs = 100\n\n  private createEntry(\n    level: LogLevel,\n    message: string,\n    data?: unknown,\n    context?: string\n  ): LogEntry {\n    return {\n      level,\n      message,\n      data,\n      timestamp: new Date().toISOString(),\n      context,\n    }\n  }\n\n  debug(message: string, data?: unknown, context?: string) {\n    if (isDevelopment) {\n      const entry = this.createEntry('debug', message, data, context)\n      console.debug(`[DEBUG] ${message}`, data ?? '')\n      this.addLog(entry)\n    }\n  }\n\n  info(message: string, data?: unknown, context?: string) {\n    const entry = this.createEntry('info', message, data, context)\n    this.addLog(entry)\n    if (isDevelopment) {\n      console.info(`[INFO] ${message}`, data ?? '')\n    }\n  }\n\n  warn(message: string, data?: unknown, context?: string) {\n    const entry = this.createEntry('warn', message, data, context)\n    this.addLog(entry)\n    if (isDevelopment) {\n      console.warn(`[WARN] ${message}`, data ?? '')\n    }\n  }\n\n  error(message: string, error?: unknown, context?: string) {\n    const entry = this.createEntry('error', message, error, context)\n    this.addLog(entry)\n    if (isDevelopment) {\n      console.error(`[ERROR] ${message}`, error ?? '')\n    }\n    this.reportError(entry)\n  }\n\n  private addLog(entry: LogEntry) {\n    this.logs.push(entry)\n    if (this.logs.length > this.maxLogs) {\n      this.logs.shift()\n    }\n  }\n\n  private reportError(_entry: LogEntry) {\n    if (isProduction) {\n      // In production, you would send to Sentry or similar\n      // Sentry?.captureException(_entry)\n    }\n  }\n\n  getLogs(): LogEntry[] {\n    return [...this.logs]\n  }\n\n  clearLogs() {\n    this.logs = []\n  }\n\n  exportLogs(): string {\n    return JSON.stringify(this.logs, null, 2)\n  }\n}\n\nexport const logger = new Logger()\n\nexport function createLogger(context: string) {\n  return {\n    debug: (message: string, data?: unknown) => logger.debug(message, data, context),\n    info: (message: string, data?: unknown) => logger.info(message, data, context),\n    warn: (message: string, data?: unknown) => logger.warn(message, data, context),\n    error: (message: string, error?: unknown) => logger.error(message, error, context),\n  }\n}\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\shiva\\Desktop\\windows_app\\learninghub\\src\\utils\\markdown.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\shiva\\Desktop\\windows_app\\learninghub\\src\\utils\\network.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\shiva\\Desktop\\windows_app\\learninghub\\src\\utils\\number.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\shiva\\Desktop\\windows_app\\learninghub\\src\\utils\\security.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\shiva\\Desktop\\windows_app\\learninghub\\src\\utils\\storage.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\shiva\\Desktop\\windows_app\\learninghub\\src\\utils\\string.ts","message