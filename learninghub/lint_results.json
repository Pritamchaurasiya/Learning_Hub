tring | null>(null)\n  const [isSubmitting, setIsSubmitting] = useState(false)\n  const [result, setResult] = useState<QuizResult | null>(null)\n  const [showConfirmDialog, setShowConfirmDialog] = useState(false)\n\n  // Connect to global quiz state\n  const { flaggedQuestions, flagQuestion, unflagQuestion } = useStore(state => ({\n    flaggedQuestions: state.quiz.flaggedQuestions,\n    flagQuestion: state.flagQuestion,\n    unflagQuestion: state.unflagQuestion,\n  }))\n\n  const [availableQuizzes, setAvailableQuizzes] = useState<Quiz[]>([])\n  const [searchQuery, setSearchQuery] = useState('')\n\n  const loadQuiz = useCallback(async () => {\n    try {\n      setIsLoading(true)\n      setError(null)\n\n      if (quizId) {\n        // Load specific quiz\n        const res = await quizService.startAttempt(quizId)\n        const sessionData = res.data\n        // Also fetch quiz info\n        const infoRes = await quizService.getQuiz(quizId)\n        setQuizInfo(infoRes.data.quiz)\n        setQuestions(sessionData.questions)\n        setAttemptId(sessionData.attempt_id)\n        setTimeRemaining(infoRes.data.quiz.time_limit * 60)\n      } else {\n        // No quizId: Load available quizzes for selection\n        const res = await quizService.listQuizzes()\n        setAvailableQuizzes(res.data)\n      }\n    } catch (err) {\n      if (import.meta.env.DEV) {\n        console.error('[QuizPage] Failed to load quiz:', err)\n      }\n      setError(\n        err instanceof Error ? err.message : 'System unavailable. Could not generate quiz session.'\n      )\n    } finally {\n      setIsLoading(false)\n    }\n  }, [quizId])\n\n  useEffect(() => {\n    loadQuiz().catch(err => {\n      if (import.meta.env.DEV) {\n        console.error('[QuizPage] useEffect loadQuiz error:', err)\n      }\n    })\n  }, [loadQuiz])\n\n  const handleSubmitClick = useCallback(() => {\n    setShowConfirmDialog(true)\n  }, [])\n\n  const handleConfirmSubmit = useCallback(async () => {\n    setShowConfirmDialog(false)\n    if (!quizInfo || !attemptId || !quizId) return\n\n    setIsSubmitting(true)\n\n    try {\n      const timeTaken = (quizInfo.time_limit ?? 0) * 60 - timeRemaining\n      const response = await quizService.submitQuiz(quizId, attemptId, answers, timeTaken)\n      setResult(response.data)\n    } catch (err) {\n      if (import.meta.env.DEV) {\n        console.error('[QuizPage] Submission failed:', err)\n      }\n      // Show error - don't fake results\n      setError(err instanceof Error ? err.message : 'Failed to submit quiz. Please try again.')\n    } finally {\n      setIsSubmitting(false)\n    }\n  }, [quizId, attemptId, questions, answers, timeRemaining, quizInfo])\n\n  // Timer effect: decrement every second\n  useEffect(() => {\n    if (!quizInfo || result || timeRemaining <= 0) return\n\n    const timer = setInterval(() => {\n      setTimeRemaining(prev => {\n        if (prev <= 1) {\n          return 0\n        }\n        return prev - 1\n      })\n    }, 1000)\n\n    return () => clearInterval(timer)\n  }, [quizInfo, result]) // Removed timeRemaining from deps to prevent interval restart\n\n  // Auto-submit when timer hits zero\n  useEffect(() => {\n    if (timeRemaining === 0 && quizInfo && attemptId && !result && !isSubmitting) {\n      handleConfirmSubmit()\n    }\n  }, [timeRemaining, quizInfo, attemptId, result, isSubmitting, handleConfirmSubmit])\n\n  const formatTime = useCallback((seconds: number) => {\n    const mins = Math.floor(seconds / 60)\n    const secs = seconds % 60\n    return `${mins}:${secs.toString().padStart(2, '0')}`\n  }, [])\n\n  const handleAnswer = useCallback((questionId: string, answer: string) => {\n    setAnswers(prev => ({ ...prev, [questionId]: answer }))\n  }, [])\n\n  const handleRetry = useCallback(async () => {\n    setCurrentQuestionIndex(0)\n    setAnswers({})\n    setResult(null)\n    await loadQuiz()\n  }, [loadQuiz])\n\n  const quizProgress = useMemo(() => {\n    if (questions.length === 0) return 0\n    return ((currentQuestionIndex + 1) / questions.length) * 100\n  }, [questions.length, currentQuestionIndex])\n\n  if (isLoading) {\n    return (\n      <div className=\"flex flex-col items-center justify-center min-h-[60vh]\">\n        <motion.div\n          animate={{ scale: [1, 1.2, 1], opacity: [0.5, 1, 0.5] }}\n          transition={{ duration: 2, repeat: Infinity }}\n          className=\"w-20 h-20 bg-primary-100 dark:bg-primary-900/20 rounded-3xl flex items-center justify-center mb-6\"\n        >\n          <Brain className=\"w-10 h-10 text-primary-500\" />\n        </motion.div>\n        <p className=\"font-bold text-gray-500 tracking-widest uppercase text-xs\">\n          Generating Session...\n        </p>\n      </div>\n    )\n  }\n\n  if (error) {\n    return (\n      <AnimatedPage>\n        <Card className=\"max-w-md mx-auto p-10 text-center mt-12 border-none shadow-2xl rounded-[2.5rem]\">\n          <div className=\"w-16 h-16 bg-red-50 dark:bg-red-900/10 rounded-2xl flex items-center justify-center mx-auto mb-6\">\n            <AlertCircle className=\"w-8 h-8 text-red-500\" />\n          </div>\n          <h3 className=\"text-xl font-black mb-3 tracking-tight\">Access Error</h3>\n          <p className=\"text-gray-500 dark:text-gray-400 mb-8 text-sm leading-relaxed\">{error}</p>\n          <Button onClick={loadQuiz} className=\"w-full py-4 rounded-2xl font-bold\">\n            Try Connection Again\n          </Button>\n        </Card>\n      </AnimatedPage>\n    )\n  }\n\n  if (!quizId) {\n    const filteredQuizzes = availableQuizzes.filter(q =>\n      q.title.toLowerCase().includes(searchQuery.toLowerCase())\n    )\n\n    return (\n      <AnimatedPage className=\"max-w-6xl mx-auto px-4 pb-12\">\n        <SEO title=\"Quiz Discovery\" />\n        <div className=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12\">\n          <div className=\"space-y-2\">\n            <h1 className=\"text-4xl font-black tracking-tighter\">Knowledge Mastery</h1>\n            <p className=\"text-gray-500 dark:text-gray-400 font-medium\">\n              Challenge yourself with our curated engineering assessments.\n            </p>\n          </div>\n          <div className=\"relative w-full md:w-96\">\n            <Search className=\"absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400\" />\n            <input\n              type=\"text\"\n              placeholder=\"Search assessments...\"\n              className=\"w-full pl-12 pr-4 py-4 rounded-2xl bg-white dark:bg-gray-900 border-none shadow-xl shadow-gray-200/20 dark:shadow-none focus:ring-2 focus:ring-primary-500 transition-all font-bold\"\n              value={searchQuery}\n              onChange={e => setSearchQuery(e.target.value)}\n            />\n          </div>\n        </div>\n\n        {filteredQuizzes.length === 0 ? (\n          <Card className=\"p-20 text-center border-none shadow-xl rounded-[3rem]\">\n            <div className=\"w-20 h-20 bg-gray-50 dark:bg-gray-800/50 rounded-3xl flex items-center justify-center mx-auto mb-6\">\n              <Search className=\"w-10 h-10 text-gray-300\" />\n            </div>\n            <h3 className=\"text-xl font-black mb-2\">No quizzes found</h3>\n            <p className=\"text-gray-500\">Try adjusting your search query or check back later.</p>\n          </Card>\n        ) : (\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n            {filteredQuizzes.map(quiz => (\n              <motion.div\n                key={quiz.id}\n                whileHover={{ y: -8 }}\n                onClick={() => navigate(`/quiz/${quiz.id}`)}\n                className=\"cursor-pointer group\"\n              >\n                <Card className=\"p-8 h-full border-none shadow-lg hover:shadow-2xl transition-all duration-500 rounded-[2.5rem] relative overflow-hidden flex flex-col\">\n                  <div className=\"absolute top-0 right-0 p-8 opacity-[0.03] group-hover:opacity-[0.07] transition-opacity pointer-events-none\">\n                    <Brain className=\"w-32 h-32\" />\n                  </div>\n\n                  <div className=\"flex items-center gap-4 mb-6\">\n                    <div className=\"w-12 h-12 rounded-2xl bg-primary-50 dark:bg-primary-900/20 flex items-center justify-center\">\n                      <Brain className=\"w-6 h-6 text-primary-600\" />\n                    </div>\n                    <div className=\"px-3 py-1 bg-gray-50 dark:bg-gray-800 rounded-lg text-[10px] font-black uppercase tracking-widest text-gray-400\">\n                      {quiz.course_title}\n                    </div>\n                  </div>\n\n                  <h3 className=\"text-xl font-black mb-3 tracking-tight group-hover:text-primary-600 transition-colors\">\n                    {quiz.title}\n                  </h3>\n                  <p className=\"text-sm text-gray-500 dark:text-gray-400 mb-8 line-clamp-2 leading-relaxed flex-1\">\n                    {quiz.description}\n                  </p>\n\n                  <div className=\"grid grid-cols-2 gap-4 mt-auto\">\n                    <div className=\"p-4 rounded-2xl bg-gray-50 dark:bg-gray-800/50\">\n                      <div className=\"flex items-center gap-2 mb-1\">\n                        <Timer className=\"w-3.5 h-3.5 text-indigo-500\" />\n                        <span className=\"text-[10px] font-black uppercase tracking-widest text-gray-400\">\n                          Time\n                        </span>\n                      </div>\n                      <p className=\"font-bold tabular-nums\">{quiz.time_limit}m</p>\n                    </div>\n                    <div className=\"p-4 rounded-2xl bg-gray-50 dark:bg-gray-800/50\">\n                      <div className=\"flex items-center gap-2 mb-1\">\n                        <Trophy className=\"w-3.5 h-3.5 text-amber-500\" />\n                        <span className=\"text-[10px] font-black uppercase tracking-widest text-gray-400\">\n                          Pass\n                        </span>\n                      </div>\n                      <p className=\"font-bold tabular-nums\">{quiz.passing_score}%</p>\n                    </div>\n                  </div>\n\n                  <div className=\"mt-6 pt-6 border-t border-gray-100 dark:border-gray-800 flex items-center justify-between\">\n                    <span className=\"text-xs font-bold text-gray-400\">\n                      {quiz.total_questions} Questions\n                    </span>\n                    <Button\n                      size=\"sm\"\n                      className=\"rounded-xl font-black text-[10px] uppercase tracking-widest px-4\"\n                    >\n                      Start Session\n                    </Button>\n                  </div>\n                </Card>\n              </motion.div>\n            ))}\n          </div>\n        )}\n      </AnimatedPage>\n    )\n  }\n\n  if (!quizInfo || questions.length === 0) return null\n\n  if (result) {\n    return (\n      <AnimatedPage className=\"max-w-3xl mx-auto px-4 pb-12\">\n        <SEO title=\"Quiz Results\" />\n        <Card className=\"p-8 sm:p-12 text-center mb-10 border-none shadow-2xl rounded-[3rem] relative overflow-hidden\">\n          <div className=\"absolute top-0 right-0 p-10 opacity-[0.05] pointer-events-none\">\n            <Trophy className=\"w-48 h-48\" />\n          </div>\n\n          <div className=\"relative mb-10 flex flex-col items-center\">\n            <div className=\"relative\">\n              <ProgressRing\n                progress={result.percentage ?? result.score}\n                size={160}\n                strokeWidth={12}\n                className=\"text-primary-500\"\n              />\n              <div className=\"absolute inset-0 flex flex-col items-center justify-center\">\n                <span className=\"text-4xl font-black tabular-nums tracking-tighter\">\n                  {result.percentage || result.score}%\n                </span>\n                <span className=\"text-[10px] font-black uppercase tracking-[0.2em] text-gray-400\">\n                  Mastery\n                </span>\n              </div>\n            </div>\n\n            <motion.div\n              initial={{ scale: 0, y: 20 }}\n              animate={{ scale: 1, y: 0 }}\n              transition={{ delay: 0.5, type: 'spring' }}\n              className=\"absolute -bottom-4 bg-white dark:bg-gray-800 px-6 py-2 rounded-2xl shadow-xl border border-gray-100 dark:border-gray-700 flex items-center gap-2\"\n            >\n              <Trophy className=\"w-4 h-4 text-amber-500\" />\n              <span className=\"text-sm font-bold\">\n                {result.passed ? 'Level Mastered!' : 'Keep Practicing'}\n              </span>\n            </motion.div>\n          </div>\n\n          <h1 className=\"text-3xl sm:text-4xl font-black mb-3 tracking-tight\">Session Concluded</h1>\n          <p className=\"text-gray-500 dark:text-gray-400 mb-10 font-medium\">\n            {result.passed\n              ? \"Outstanding! You've mastered these concepts.\"\n              : 'Focus on the course material and try again.'}\n          </p>\n\n          <div className=\"grid grid-cols-3 gap-4 mb-10\">\n            {[\n              {\n                label: 'Mastery',\n                value: `${result.percentage || result.score}%`,\n                color: 'text-primary-500',\n                bg: 'bg-primary-50 dark:bg-primary-900/10',\n              },\n              {\n                label: 'Accuracy',\n                value: `${result.correct_answers}/${result.total_questions}`,\n                color: 'text-emerald-500',\n                bg: 'bg-emerald-50 dark:bg-emerald-900/10',\n              },\n              {\n                label: 'Duration',\n                value: `${Math.floor(result.time_taken / 60)}m ${result.time_taken % 60}s`,\n                color: 'text-indigo-500',\n                bg: 'bg-indigo-50 dark:bg-indigo-900/10',\n              },\n            ].map(stat => (\n              <div\n                key={stat.label}\n                className={`${stat.bg} p-6 rounded-[2rem] border border-transparent`}\n              >\n                <p\n                  className={`text-2xl sm:text-3xl font-black ${stat.color} mb-1 tracking-tighter`}\n                >\n                  {stat.value}\n                </p>\n                <p className=\"text-[10px] font-black uppercase tracking-[0.2em] text-gray-400\">\n                  {stat.label}\n                </p>\n              </div>\n            ))}\n          </div>\n\n          <div className=\"flex gap-4 flex-col sm:flex-row\">\n            <Button\n              onClick={handleRetry}\n              variant=\"outline\"\n              className=\"flex-1 py-4 rounded-2xl font-bold border-2\"\n            >\n              <RotateCcw className=\"w-4 h-4 mr-2\" /> Retake Quiz\n            </Button>\n            <Button\n              onClick={() => navigate('/')}\n              className=\"flex-1 py-4 rounded-2xl font-bold shadow-xl shadow-primary-500/20\"\n            >\n              Back to Dashboard <ChevronRight className=\"w-4 h-4 ml-2\" />\n            </Button>\n          </div>\n        </Card>\n\n        <div className=\"space-y-6\">\n          <h2 className=\"text-xl font-black tracking-tight px-2 flex items-center gap-2\">\n            <Info className=\"w-5 h-5 text-primary-500\" />\n            Detailed Breakdown\n          </h2>\n          {questions.map((q, index) => {\n            const userAnswer = answers[q.id]\n            const isCorrect = userAnswer === q.correct_answer\n            return (\n              <motion.div\n                key={q.id}\n                initial={{ opacity: 0, y: 10 }}\n                animate={{ opacity: 1, y: 0 }}\n                transition={{ delay: index * 0.1 }}\n              >\n                <Card\n                  className={`p-6 sm:p-8 rounded-[2rem] border shadow-sm ${isCorrect ? 'border-emerald-100 dark:border-emerald-900/20' : 'border-red-100 dark:border-red-900/20'}`}\n                >\n                  <div className=\"flex items-start gap-4\">\n                    <div\n                      className={`w-10 h-10 rounded-xl flex items-center justify-center shrink-0 mt-1 ${isCorrect ? 'bg-emerald-100 text-emerald-600' : 'bg-red-100 text-red-600'}`}\n                    >\n                      {isCorrect ? (\n                        <CheckCircle className=\"w-5 h-5\" />\n                      ) : (\n                        <XCircle className=\"w-5 h-5\" />\n                      )}\n                    </div>\n                    <div className=\"flex-1 min-w-0 space-y-4\">\n                      <div>\n                        <p className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 mb-2\">\n                          Question {index + 1}\n                        </p>\n                        <p className=\"font-bold text-lg leading-snug tracking-tight\">\n                          {q.question}\n                        </p>\n                      </div>\n                      <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-3\">\n                        <div className=\"p-4 rounded-2xl bg-gray-50 dark:bg-gray-800/50\">\n                          <p className=\"text-[10px] font-black uppercase tracking-widest text-gray-400 mb-1\">\n                            Your Choice\n                          </p>\n                          <p\n                            className={`font-bold ${isCorrect ? 'text-emerald-600' : 'text-red-600'}`}\n                          >\n                            {userAnswer || 'Timed Out'}\n                          </p>\n                        </div>\n                        {!isCorrect && (\n                          <div className=\"p-4 rounded-2xl bg-emerald-50 dark:bg-emerald-900/20\">\n                            <p className=\"text-[10px] font-black uppercase tracking-widest text-emerald-600 mb-1\">\n                              Correct Answer\n                            </p>\n                            <p className=\"font-bold text-emerald-700 dark:text-emerald-400\">\n                              {q.correct_answer}\n                            </p>\n                          </div>\n                        )}\n                      </div>\n                      <div className=\"bg-gray-50 dark:bg-gray-800 p-5 rounded-2xl italic text-sm text-gray-500 leading-relaxed border-l-4 border-primary-500\">\n                        {q.explanation}\n                      </div>\n                    </div>\n                  </div>\n                </Card>\n              </motion.div>\n            )\n          })}\n        </div>\n      </AnimatedPage>\n    )\n  }\n\n  const currentQuestion = questions[currentQuestionIndex]\n  const isLastQuestion = currentQuestionIndex === questions.length - 1\n  const displayOptions =\n    currentQuestion.options || (currentQuestion.type === 'true_false' ? ['True', 'False'] : [])\n\n  return (\n    <AnimatedPage className=\"max-w-4xl mx-auto px-4 pb-12\">\n      <SEO title=\"Active Quiz\" />\n\n      {/* Session Header */}\n      <div className=\"flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 mb-10\">\n        <div>\n          <div className=\"flex items-center gap-3 mb-2\">\n            <div className=\"w-12 h-12 rounded-2xl bg-primary-600 flex items-center justify-center shadow-xl shadow-primary-500/20\">\n              <Brain className=\"w-6 h-6 text-white\" />\n            </div>\n            <h1 className=\"text-2xl sm:text-3xl font-black tracking-tight leading-none\">\n              {quizInfo.title}\n            </h1>\n          </div>\n          <p className=\"text-gray-500 dark:text-gray-400 font-medium text-sm sm:pl-15\">\n            {quizInfo.description}\n          </p>\n        </div>\n\n        <div\n          className={`flex items-center gap-3 px-6 py-4 rounded-[2rem] border-2 transition-all shadow-xl ${timeRemaining < 60 ? 'bg-red-50 border-red-200 text-red-600 animate-pulse' : 'bg-white dark:bg-gray-800 border-gray-100 dark:border-gray-700'}`}\n        >\n          <Timer className=\"w-5 h-5\" />\n          <span className=\"font-black text-xl tabular-nums tracking-tighter\">\n            {formatTime(timeRemaining)}\n          </span>\n        </div>\n      </div>\n\n      {/* Progress Tracker */}\n      <div className=\"mb-10 px-2\">\n        <div className=\"flex justify-between items-end mb-4\">\n          <div className=\"flex flex-col\">\n            <span className=\"text-[10px] font-black uppercase tracking-[0.2em] text-gray-400 mb-1\">\n              Current Progress\n            </span>\n            <span className=\"text-lg font-black text-primary-600\">\n              {currentQuestionIndex + 1}{' '}\n              <span className=\"text-gray-300 font-medium text-sm\">of {questions.length}</span>\n            </span>\n          </div>\n          <span className=\"text-xs font-black text-gray-400 bg-gray-100 dark:bg-gray-800 px-3 py-1 rounded-full\">\n            {Math.round(quizProgress)}%\n          </span>\n        </div>\n        <div className=\"h-2.5 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden p-0.5\">\n          <motion.div\n            className=\"h-full bg-gradient-to-r from-primary-500 to-indigo-600 rounded-full relative\"\n            initial={{ width: 0 }}\n            animate={{ width: `${quizProgress}%` }}\n            transition={{ type: 'spring', stiffness: 100, damping: 20 }}\n          >\n            <div className=\"absolute inset-0 shimmer opacity-30\" />\n          </motion.div>\n        </div>\n      </div>\n\n      {/* Question Interaction Area */}\n      <motion.div\n        key={currentQuestion.id}\n        initial={{ opacity: 0, x: 20 }}\n        animate={{ opacity: 1, x: 0 }}\n        exit={{ opacity: 0, x: -20 }}\n        transition={{ duration: 0.3 }}\n      >\n        <Card className=\"p-8 sm:p-12 rounded-[3rem] border-none shadow-2xl relative overflow-hidden mb-8\">\n          <div className=\"absolute top-0 right-0 p-8 opacity-[0.03] pointer-events-none\">\n            <Sparkles className=\"w-32 h-32\" />\n          </div>\n\n          {/* Question Navigation Grid */}\n          <div className=\"mb-8 p-4 bg-gray-50 dark:bg-gray-800/50 rounded-2xl\">\n            <div className=\"flex items-center justify-between mb-3\">\n              <span className=\"text-sm font-bold text-gray-600 dark:text-gray-400\">\n                Question Navigator\n              </span>\n              <span className=\"text-xs text-gray-500 dark:text-gray-500\">\n                {Object.keys(answers).length} of {questions.length} answered\n              </span>\n            </div>\n            <div className=\"grid grid-cols-10 gap-2\">\n              {questions.map((q, idx) => {\n                const isAnswered = answers[q.id] !== undefined\n                const isFlagged = flaggedQuestions.includes(q.id)\n                const isCurrent = idx === currentQuestionIndex\n\n                return (\n                  <button\n                    key={q.id}\n                    onClick={() => setCurrentQuestionIndex(idx)}\n                    className={`\n                        relative w-10 h-10 rounded-xl text-sm font-bold transition-all duration-200\n                        ${\n                          isCurrent\n                            ? 'bg-primary-500 text-white ring-2 ring-primary-300 ring-offset-2 dark:ring-offset-gray-800'\n                            : isAnswered\n                              ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400'\n                              : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-600'\n                        }\n                      `}\n                    title={`Question ${idx + 1}${isFlagged ? ' (Flagged)' : ''}`}\n                  >\n                    {idx + 1}\n                    {isFlagged && (\n                      <span className=\"absolute -top-1 -right-1 w-3 h-3 bg-amber-400 rounded-full border-2 border-white dark:border-gray-800\" />\n                    )}\n                  </button>\n                )\n              })}\n            </div>\n          </div>\n\n          <div className=\"mb-10 space-y-4\">\n            <div className=\"flex items-center justify-between\">\n              <span className=\"inline-block px-4 py-1.5 bg-primary-50 dark:bg-primary-900/20 text-primary-600 text-[10px] font-black uppercase tracking-widest rounded-xl\">\n                Difficulty Award: {currentQuestion.points} XP\n              </span>\n              <button\n                onClick={() => {\n                  if (flaggedQuestions.includes(currentQuestion.id)) {\n                    unflagQuestion(currentQuestion.id)\n                  } else {\n                    flagQuestion(currentQuestion.id)\n                  }\n                }}\n                className={`\n                    flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-bold transition-all duration-200\n                    ${\n                      flaggedQuestions.includes(currentQuestion.id)\n                        ? 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400'\n                        : 'bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 hover:bg-gray-200 dark:hover:bg-gray-700'\n                    }\n                  `}\n              >\n                <Flag\n                  className={`w-4 h-4 ${flaggedQuestions.includes(currentQuestion.id) ? 'fill-current' : ''}`}\n                />\n                {flaggedQuestions.includes(currentQuestion.id) ? 'Flagged' : 'Flag for Review'}\n              </button>\n            </div>\n            <h2 className=\"text-2xl sm:text-3xl font-black leading-tight tracking-tight text-gray-900 dark:text-white\">\n              {currentQuestion.question}\n            </h2>\n          </div>\n\n          <div className=\"grid grid-cols-1 gap-4\" role=\"radiogroup\">\n            {displayOptions.map((option, idx) => {\n              const isSelected = answers[currentQuestion.id] === option\n              return (\n                <motion.button\n                  key={option}\n                  whileHover={{ scale: 1.01 }}\n                  whileTap={{ scale: 0.99 }}\n                  onClick={() => handleAnswer(currentQuestion.id, option)}\n                  className={`group w-full text-left p-6 rounded-[2rem] border-2 transition-all duration-300 flex items-center justify-between ${\n                    isSelected\n                      ? 'border-primary-500 bg-primary-50/50 dark:bg-primary-900/10 shadow-lg shadow-primary-500/5'\n                      : 'border-gray-100 dark:border-gray-800 hover:border-gray-200 dark:hover:border-gray-700'\n                  }`}\n                >\n                  <div className=\"flex items-center gap-6\">\n                    <div\n                      className={`w-10 h-10 rounded-2xl border-2 flex items-center justify-center font-black transition-all ${\n                        isSelected\n                          ? 'bg-primary-500 border-primary-500 text-white'\n                          : 'border-gray-200 dark:border-gray-700 text-gray-400 group-hover:border-primary-200'\n                      }`}\n                    >\n                      {String.fromCharCode(65 + idx)}\n                    </div>\n                    <span\n                      className={`font-bold text-lg tracking-tight ${isSelected ? 'text-primary-700 dark:text-primary-400' : 'text-gray-600 dark:text-gray-300'}`}\n                    >\n                      {option}\n                    </span>\n                  </div>\n                  {isSelected && (\n                    <motion.div initial={{ scale: 0 }} animate={{ scale: 1 }}>\n                      <CheckCircle className=\"w-6 h-6 text-primary-500\" />\n                    </motion.div>\n                  )}\n                </motion.button>\n              )\n            })}\n          </div>\n        </Card>\n      </motion.div>\n\n      {/* Control Actions */}\n      <div className=\"flex flex-col sm:flex-row items-center justify-between gap-6 px-4\">\n        <button\n          onClick={() => currentQuestionIndex > 0 && setCurrentQuestionIndex(prev => prev - 1)}\n          disabled={currentQuestionIndex === 0}\n          className=\"flex items-center gap-3 font-black uppercase tracking-widest text-xs text-gray-400 hover:text-gray-600 disabled:opacity-30 transition-all p-4\"\n        >\n          <ChevronLeft className=\"w-5 h-5\" /> Previous Logic\n        </button>\n\n        <div className=\"flex items-center gap-4 w-full sm:w-auto\">\n          {isLastQuestion ? (\n            <Button\n              onClick={handleSubmitClick}\n              isLoading={isSubmitting}\n              disabled={Object.keys(answers).length < questions.length}\n              className=\"w-full sm:w-64 py-6 rounded-[2rem] font-black text-lg shadow-2xl shadow-primary-500/30\"\n            >\n              Submit Session\n            </Button>\n          ) : (\n            <Button\n              onClick={() => setCurrentQuestionIndex(prev => prev + 1)}\n              disabled={!answers[currentQuestion.id]}\n              className=\"w-full sm:w-64 py-6 rounded-[2rem] font-black text-lg shadow-2xl shadow-primary-500/30\"\n            >\n              Advance Next <ChevronRight className=\"w-5 h-5 ml-2\" />\n            </Button>\n          )}\n        </div>\n      </div>\n\n      {/* Confirm Submission Dialog */}\n      {showConfirmDialog && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm\">\n          <motion.div\n            initial={{ opacity: 0, scale: 0.95 }}\n            animate={{ opacity: 1, scale: 1 }}\n            exit={{ opacity: 0, scale: 0.95 }}\n            className=\"bg-white dark:bg-gray-900 rounded-3xl p-8 max-w-md w-full shadow-2xl\"\n          >\n            <div className=\"text-center mb-6\">\n              <div className=\"w-16 h-16 bg-amber-100 dark:bg-amber-900/20 rounded-2xl flex items-center justify-center mx-auto mb-4\">\n                <AlertCircle className=\"w-8 h-8 text-amber-600\" />\n              </div>\n              <h3 className=\"text-xl font-black mb-2\">Submit Quiz?</h3>\n              <p className=\"text-gray-500 dark:text-gray-400 text-sm\">\n                You have answered {Object.keys(answers).length} of {questions.length} questions.\n              </p>\n              {flaggedQuestions.length > 0 && (\n                <p className=\"text-amber-600 text-sm mt-2 font-medium\">\n                  <Flag className=\"w-4 h-4 inline mr-1\" />\n                  {flaggedQuestions.length} question{flaggedQuestions.length > 1 ? 's' : ''} flagged\n                  for review\n                </p>\n              )}\n            </div>\n\n            <div className=\"space-y-3\">\n              <Button\n                onClick={handleConfirmSubmit}\n                isLoading={isSubmitting}\n                className=\"w-full py-4 rounded-2xl font-bold\"\n              >\n                Yes, Submit Now\n              </Button>\n              <Button\n                onClick={() => setShowConfirmDialog(false)}\n                variant=\"outline\"\n                className=\"w-full py-4 rounded-2xl font-bold border-2\"\n              >\n                Go Back & Review\n              </Button>\n            </div>\n          </motion.div>\n        </div>\n      )}\n    </AnimatedPage>\n  )\n}\n\nexport default memo(QuizPage)\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\shiva\\Desktop\\windows_app\\learninghub\\src\\pages\\SearchPage.tsx","messages":[{"ruleId":"@typescript-e