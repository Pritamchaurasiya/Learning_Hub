ion: questionId => {\n    set(state => ({\n      testsA: {\n        ...state.testsA,\n        flaggedQuestions: [...state.testsA.flaggedQuestions, questionId],\n      },\n    }))\n  },\n\n  // Unflag a question\n  unflagQuestion: questionId => {\n    set(state => ({\n      testsA: {\n        ...state.testsA,\n        flaggedQuestions: state.testsA.flaggedQuestions.filter(id => id !== questionId),\n      },\n    }))\n  },\n\n  // Navigate to a specific question\n  navigateToQuestion: index => {\n    set(state => ({\n      testsA: {\n        ...state.testsA,\n        currentQuestionIndex: index,\n      },\n    }))\n  },\n\n  // Update timer\n  updateTestTimer: timeRemaining => {\n    set(state => ({\n      testsA: {\n        ...state.testsA,\n        timeRemaining,\n      },\n    }))\n  },\n\n  // Set questions after starting test\n  setTestQuestions: (questions, testInfo) => {\n    set(state => ({\n      testsA: {\n        ...state.testsA,\n        questions,\n        testInfo,\n        isLoading: false,\n      },\n    }))\n  },\n\n  // Submit test\n  submitTest: async () => {\n    const { testsA } = get()\n    const { testInfo, answers, attemptId, timeRemaining } = testsA\n\n    if (!testInfo || !attemptId) {\n      return { success: false, score: 0 }\n    }\n\n    set(state => ({ testsA: { ...state.testsA, isLoading: true } }))\n\n    try {\n      const timeTaken = testInfo.timeLimit * 60 - timeRemaining\n\n      // Convert answers to the format expected by the API\n      const formattedAnswers: Record<string, string> = {}\n      Object.entries(answers).forEach(([questionId, optionIndex]) => {\n        formattedAnswers[questionId] = optionIndex.toString()\n      })\n\n      const response = await testsAService.submitTest(\n        testInfo.testId,\n        attemptId,\n        formattedAnswers,\n        timeTaken\n      )\n\n      if (response.status === 'success') {\n        set(state => ({\n          testsA: {\n            ...state.testsA,\n            isActive: false,\n            results: response.data,\n            isLoading: false,\n          },\n        }))\n        return { success: true, score: response.data.score }\n      }\n\n      set(state => ({\n        testsA: {\n          ...state.testsA,\n          isLoading: false,\n          error: 'Failed to submit test',\n        },\n      }))\n      return { success: false, score: 0 }\n    } catch (error) {\n      set(state => ({\n        testsA: {\n          ...state.testsA,\n          isLoading: false,\n          error: error instanceof Error ? error.message : 'Failed to submit test',\n        },\n      }))\n      return { success: false, score: 0 }\n    }\n  },\n\n  // Reset test state\n  resetTestState: () => {\n    set({ testsA: initialTestsAState })\n  },\n\n  // Abandon test\n  abandonTest: () => {\n    set({\n      testsA: {\n        ...initialTestsAState,\n        isActive: false,\n      },\n    })\n  },\n\n  // Set test results\n  setTestResults: results => {\n    set(state => ({\n      testsA: {\n        ...state.testsA,\n        results,\n        isActive: false,\n      },\n    }))\n  },\n})\n\nexport default createTestsASlice\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\shiva\\Desktop\\windows_app\\learninghub\\src\\stores\\slices\\uiSlice.ts","messages":[{"ruleId":"@typescript-eslint/prefer-nullish-coalescing","severity":2,"message":"Prefer using nullish coalescing operator (`??`) instead of a logical or (`||`), as it is a safer operator.","line":29,"column":23,"nodeType":"Punctuator","messageId":"preferNullishOverOr","endLine":29,"endColumn":25,"suggestions":[{"messageId":"suggestNullish","data":{"equals":""},"fix":{"range":[887,889],"text":"??"},"desc":"Fix to nullish coalescing operator (`??`)."}]}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { StateCreator } from 'zustand'\nimport { AppState, UISlice } from '../types'\n\nlet toastCounter = 0\nfunction g