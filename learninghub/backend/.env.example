# ============================================
# LearningHub Backend Environment Configuration
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="file:./dev.db"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Logging Configuration
# 0=ERROR, 1=WARN, 2=INFO, 3=DEBUG
LOG_LEVEL=2

# Rate Limiting Configuration
# General API rate limiting
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=100

# Auth endpoint rate limiting (stricter)
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5

# Admin endpoint rate limiting (ultra-strict)
RATE_LIMIT_ADMIN_WINDOW_MS=900000
RATE_LIMIT_ADMIN_MAX=30

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads/

# Email Configuration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@learninghub.com

# Redis Configuration (optional - for distributed rate limiting)
REDIS_URL=
REDIS_ENABLED=false

# Audit Logging Configuration
AUDIT_LOG_TO_CONSOLE=true
AUDIT_LOG_TO_DATABASE=false
AUDIT_LOG_RETENTION_DAYS=90
