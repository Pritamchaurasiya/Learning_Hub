# ============================================
# LearningHub Backend Environment Configuration
# ============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Options: "sqlite" | "postgresql"
DB_PROVIDER=sqlite

# SQLite (Local Development)
DATABASE_URL="file:./dev.db"
DIRECT_URL="file:./dev.db"

# PostgreSQL (Production - Neon or self-hosted)
# DB_PROVIDER=postgresql
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&connection_limit=10&pool_timeout=10"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# ============================================
# AI Configuration (REQUIRED for AI features)
# ============================================
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# Payment Configuration (REQUIRED for payments)
# ============================================
# Get your keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
# Frontend URL for payment redirects
FRONTEND_URL=http://localhost:5173

# ============================================
# Max test attempts per user (default: 3)
# ============================================
MAX_TEST_ATTEMPTS=3

# Logging Configuration
# 0=ERROR, 1=WARN, 2=INFO, 3=DEBUG
LOG_LEVEL=2

# Rate Limiting Configuration
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_ADMIN_WINDOW_MS=900000
RATE_LIMIT_ADMIN_MAX=30

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads/

# Email Configuration (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@learninghub.com

# Redis Configuration (optional - for distributed rate limiting & caching)
REDIS_URL=
REDIS_ENABLED=false

# Admin Configuration
ADMIN_SECRET=your-secure-admin-secret-key-min-16-chars
ADMIN_EMAIL=admin@learninghub.app
# IMPORTANT: Change this immediately after first login
ADMIN_DEFAULT_PASSWORD=ChangeMeImmediately123!

# Audit Logging Configuration
AUDIT_LOG_TO_CONSOLE=true
AUDIT_LOG_TO_DATABASE=false
AUDIT_LOG_RETENTION_DAYS=90

# Max concurrent sessions per user
MAX_SESSIONS_PER_USER=5
