# Production Environment Configuration
NODE_ENV=production
PORT=5000

# PostgreSQL Database (Neon or AWS RDS)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/learninghub?sslmode=require
DIRECT_URL=postgresql://username:password@ep-xxx-xxx.us-east-1.aws.neon.tech/learninghub?sslmode=require

# Connection Pool Settings
DATABASE_CONNECTION_LIMIT=20
DATABASE_POOL_TIMEOUT=30
DATABASE_STATEMENT_CACHE_SIZE=100

# Redis Cache (Upstash or AWS ElastiCache)
REDIS_URL=rediss://default:password@xxx.upstash.io:6379
REDIS_TOKEN=your-upstash-token

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Security
BCRYPT_ROUNDS=12
CORS_ORIGIN=https://learninghub.app
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_ADMIN_WINDOW_MS=900000
RATE_LIMIT_ADMIN_MAX=30

# Session Management
SESSION_SECRET=another-super-secret-session-key
MAX_SESSIONS_PER_USER=5

# Email/SMTP (SendGrid/AWS SES)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=noreply@learninghub.app
FROM_NAME=LearningHub

# Cloud Storage (AWS S3/Cloudflare R2)
S3_BUCKET=learninghub-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# Monitoring & Logging
LOG_LEVEL=info
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
DATADOG_API_KEY=your-datadog-key

# Feature Flags
ENABLE_AI_TUTOR=true
ENABLE_LIVE_CLASSES=true
ENABLE_MENTORSHIP=true
ENABLE_PAYMENTS=true

# API Keys for External Services
OPENAI_API_KEY=sk-xxx
HUGGINGFACE_API_KEY=hf_xxx

# Admin Configuration
ADMIN_EMAIL=admin@learninghub.app
ADMIN_DEFAULT_PASSWORD=ChangeMeImmediately123!

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS_PER_USER=3
